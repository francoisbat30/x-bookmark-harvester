# Dependencies
node_modules/

# Build output
.next/
out/
dist/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db
desktop.ini
**/desktop.ini

# Screenshots and scratch images at repo root (user-local, not repo assets)
/Capture*.png
/Capture*.jpg
/screenshot*.png
/screenshot*.jpg

# Environment — NEVER commit real secrets
.env
.env.local
.env*.local
!.env.example

# Auth tokens (legacy path — current path is in %APPDATA%)
.auth.json
**/.auth.json

# Claude Code local settings (keep shared skills + settings.json) — any depth
**/.claude/settings.local.json
**/.claude/.credentials/

# Editor / IDE
.vscode/
.idea/
*.swp

# Vault content — keep directory structure via .gitkeep, ignore everything else
vault/*
!vault/x-bookmarks
vault/x-bookmarks/*
!vault/x-bookmarks/.gitkeep
!vault/x-bookmarks/assets
vault/x-bookmarks/assets/*
!vault/x-bookmarks/assets/.gitkeep
