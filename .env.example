# xAI / Grok API — used to extract X post content
# Get your key at https://console.x.ai
XAI_API_KEY=

# Grok model to use for extraction
XAI_MODEL=grok-4

# X API v2 — App-only Bearer Token (reads public tweets + conversations)
# Get yours at developer.x.com → your app → Keys and tokens → Bearer Token
X_API_BEARER_TOKEN=

# X API v2 — OAuth 2.0 user context (for authenticated bookmarks sync)
# developer.x.com → app → User authentication settings → enable OAuth 2.0
# X does NOT accept localhost in redirect URIs — use 127.0.0.1
# Set redirect URI to: http://127.0.0.1:3000/callback
# Then: Keys and tokens → OAuth 2.0 Client ID and Client Secret
X_OAUTH2_CLIENT_ID=
X_OAUTH2_CLIENT_SECRET=
X_OAUTH2_REDIRECT_URI=http://127.0.0.1:3000/callback

# Absolute or relative path to the Obsidian vault root
# Default: ./vault (local test vault inside this project)
OBSIDIAN_VAULT_PATH=./vault

# Subfolder inside the vault where bookmark notes are written
OBSIDIAN_BOOKMARKS_SUBFOLDER=x-bookmarks
